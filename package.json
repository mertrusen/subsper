{
  "name": "subsper",
  "productName": "Subsper",
  "version": "1.6.2",
  "description": "Subsper — AI subtitles, audio cleanup & silence cutting. By zipheron.",
  "main": "electron-main.js",
  "author": "zipheron",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "prep": "node scripts/fetch-binaries.mjs",
    "dist:win": "npm run prep && electron-builder --win --x64 --publish never",
    "dist:mac": "npm run prep && electron-builder --mac --publish never",
    "dist": "electron-builder -mw --publish never"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "ffmpeg-static": "^5.3.0"
  },
  "build": {
    "appId": "com.zipheron.subsper",
    "productName": "Subsper",
    "files": [
      "electron-main.js",
      "index.html",
      "css/**/*",
      "js/**/*",
      "scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts"
      },
      {
        "from": "bin",
        "to": "bin"
      },
      {
        "from": "js/whispercpp.js",
        "to": "js/whispercpp.js"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Subsper-Setup-${version}.${ext}",
      "publisherName": "zipheron"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "public.app-category.video",
      "artifactName": "Subsper-${version}-mac.${ext}",
      "identity": null
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "icon": "build/icon.png"
  },
  "dependencies": {
    "diff": "^9.0.0"
  }
}
